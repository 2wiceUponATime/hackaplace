{
	"name": "hackaplace",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "next dev",
		"build": "next build",
		"start": "next start",
		"lint": "next lint",
		"deploy": "pnpx @opennextjs/cloudflare build && pnpx @opennextjs/cloudflare deploy",
		"upload": "pnpx @opennextjs/cloudflare build && pnpx @opennextjs/cloudflare upload",
		"preview": "pnpx @opennextjs/cloudflare build && pnpx @opennextjs/cloudflare preview",
		"cf-typegen": "wrangler types --env-interface CloudflareEnv ./cloudflare-env.d.ts",
		"supabase-typegen": "pnpx supabase gen types typescript --schema public > src/lib/supabase.types.ts"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"@opennextjs/cloudflare": "^1.19.2",
		"@supabase/supabase-js": "^2.103.3",
		"better-auth": "^1.6.5",
		"konva": "^10.2.5",
		"next": "16.1.5",
		"react": "^19.1.6",
		"react-konva": "^19.0.10",
		"react-toastify": "^11.0.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3",
		"@tailwindcss/postcss": "^4",
		"@types/node": "^20",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.1.17",
		"eslint": "^9",
		"eslint-config-next": "15.4.6",
		"tailwindcss": "^4",
		"typescript": "^5.7.4",
		"wrangler": "^4.78.0"
	}
}